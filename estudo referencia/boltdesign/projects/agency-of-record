5-4235-9bf7-729f65c94676","title":"Project Management"},{"_id":"624dbe00-21b7-4315-a7f5-cdf2b5e59fd2","title":"Lighting Design"},{"_id":"7e2ee61d-f4e0-40cf-b15b-c53eb5bd15cc","title":"Custom Fabrication"},{"_id":"b2848913-e37f-47b4-aa20-f19f1ead3183","title":"Rendering"},{"_id":"fe0308ac-03f7-4827-b676-f743b8713294","title":"Construction Management"},{"_id":"bdf7ece5-8320-41db-b176-8186963ec1db","title":"Permit Acquisition"},{"_id":"c9f5820c-c5ab-4589-86bd-2c1a68fb6583","title":"Architecture (Coordination)"},{"_id":"b2ea56a8-5e15-47a5-b047-f8cbac29314e","title":"Engineering (Coordination)"}],"size":"3,000 SF","slug":"agency-of-record","tags":[{"_id":"524f11e7-aa90-4ddd-9b1e-6bfc8b8d2ea7","_type":"tag","slug":"hospitality","title":"Hospitality"}],"timeline":"11 months","title":"Agency of Record"},"nextProject":{"_id":"a3166e09-07fb-4d2b-bfec-383fca762050","_type":"project","completedAt":"2025-01-01","description":[{"_key":"619a2cdade8e","_type":"block","children":[{"_key":"0c0d844f8fe1","_type":"span","marks":["strong"],"text":"Soft Bar | Thoughtful Design Meets Mindful Hospitality by Bolt Builds"},{"_key":"b72cd3beda81","_type":"span","marks":[],"text":"\n \nBolt Builds partnered with Carl Radke to design and build Soft Bar, a first-of-its-kind non-alcoholic bar and café in Greenpoint, Brooklyn. Created as a stylish and inclusive alternative to traditional nightlife, Soft Bar redefines how New Yorkers can gather, socialize, and enjoy drinks without alcohol. Inspired by Radke’s own five-year sobriety journey, the concept goes beyond the typical sterile NA lounge to become a versatile third-space for wellness, creativity, and community connection."}],"markDefs":[],"style":"normal"},{"_key":"2731a48b4c43","_type":"block","children":[{"_key":"98a7d80ce6e00","_type":"span","marks":[],"text":"The 2,300-square-foot space, once an industrial garage, has been transformed through Bolt’s integrated design and fabrication approach. Exposed brick and concrete floors set the stage for a space softened by natural materials, warm wood fixtures, plush seating, and muted pastel tones, while a striking glass façade and infinite bar create a sense of openness and flow. From morning through evening, Soft Bar evolves effortlessly: serving locally roasted coffee and functional adaptogen drinks during the day, offering a welcoming workspace and creative studio, and transforming into a soft-cocktail bar and event destination at night."}],"markDefs":[],"style":"normal"},{"_key":"f8579cf9648a","_type":"block","children":[{"_key":"fc41a417f5520","_type":"span","marks":[],"text":"More than just a bar, the project embodies Radke’s mission to create a safe, stylish, and health-conscious space where anyone, sober, sober-curious, or simply seeking something new, can feel at home. Through thoughtful design and fabrication, Bolt Builds helped bring Soft Bar to life, setting a new standard for non-alcoholic hospitality in New York City."}],"markDefs":[],"style":"normal"}],"descriptionPlaintext":"Soft Bar | Thoughtful Design Meets Mindful Hospitality by Bolt Builds\n \nBolt Builds partnered with Carl Radke to design and build Soft Bar, a first-of-its-kind non-alcoholic bar and café in Greenpoint, Brooklyn. Created as a stylish and inclusive alternative to traditional nightlife, Soft Bar redefines how New Yorkers can gather, socialize, and enjoy drinks without alcohol. Inspired by Radke’s own five-year sobriety journey, the concept goes beyond the typical sterile NA lounge to become a versatile third-space for wellness, creativity, and community connection.\n\nThe 2,300-square-foot space, once an industrial garage, has been transformed through Bolt’s integrated design and fabrication approach. Exposed brick and concrete floors set the stage for a space softened by natural materials, warm wood fixtures, plush seating, and muted pastel tones, while a striking glass façade and infinite bar create a sense of openness and flow. From morning through evening, Soft Bar evolves effortlessly: serving locally roasted coffee and functional adaptogen drinks during the day, offering a welcoming workspace and creative studio, and transforming into a soft-cocktail bar and event destination at night.\n\nMore than just a bar, the project embodies Radke’s mission to create a safe, stylish, and health-conscious space where anyone, sober, sober-curious, or simply seeking something new, can feel at home. Through thoughtful design and fabrication, Bolt Builds helped bring Soft Bar to life, setting a new standard for non-alcoholic hospitality in New York City.","featuredImage":{"_key":null,"_type":"image","asset":{"_id":"image-cf4cfb75afe4c6a5de7a3167839648d9cd3262bc-1536x1024-jpg","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":1.5,"height":1024,"width":1536},"lqip":"data:image/jpeg;base64,"},"tags":null},"caption":null,"crop":null},"images":[{"_key":"f9a67a6ae2eb","_type":"projectImage","asset":{"_id":"image-62a075ebcfe5a9756a3db21bf2a47df0b1dff4b6-1080x1440-jpg","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":0.75,"height":1440,"width":1080},"lqip":"data:image/jpeg;base64,"},"tags":null},"caption":null,"crop":null},{"_key":"8c19e443d641","_type":"projectImage","asset":{"_id":"image-bcddbc60824c4c3b3959e4bccf250802a8967153-1080x1440-jpg","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":0.75,"height":1440,"width":1080},"lqip":"data:image/jpeg;base64,"},"tags":null},"caption":null,"crop":null},{"_key":"834cb1b0e17b","_type":"projectImage","asset":{"_id":"image-0b65d2c9b4849301f61eb26f8479046e2e0220d1-4000x5600-jpg","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":0.7142857142857143,"height":5600,"width":4000},"lqip":"data:image/jpeg;base64,"},"tags":null},"caption":null,"crop":null},{"_key":"2e6bc664b4ea","_type":"projectImage","asset":{"_id":"image-a9783f44e073ddd98d617d674f8e85c92576e075-1080x14