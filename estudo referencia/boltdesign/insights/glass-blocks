192a12b5ab04988d37faa6d059b510807fe86e8-2048x1536-png","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":1.3333333333333333,"height":1536,"width":2048},"lqip":"data:image/png;base64,"},"tags":null},"caption":null,"crop":null},{"_key":"ce34d4881e89","_type":"block","children":[{"_key":"eaa8ca6d2b980","_type":"span","marks":[],"text":"In Reflect Architecture’s project for Lumea, a sweeping glass block wall anchors the entrance of the space. Diffusing light, softening acoustics, and adding a sculptural, timeless presence to the interior. Its gentle curve and translucent texture create a luminous backdrop that balances privacy with openness.\n"}],"markDefs":[],"style":"normal"},{"_key":"6d443b0f1ed8","_type":"image","alt":"lumea glass blocks","asset":{"_id":"image-9b444a1e9df6f3b1bbbe6aef95fe10fd3a3c83ce-1536x2048-png","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":0.75,"height":2048,"width":1536},"lqip":"data:image/png;base64,"},"tags":null},"caption":null,"crop":null},{"_key":"8b6f4d36578d","_type":"block","children":[{"_key":"5e151778332b","_type":"span","marks":[],"text":""}],"markDefs":[],"style":"normal"},{"_key":"ca5794ae2a61","_type":"image","alt":" Maison Hermès glass blocks","asset":{"_id":"image-d72220967ff7ad6c96b71cb5fab8158bc7c6108a-1600x1261-jpg","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":1.26883425852498,"height":1261,"width":1600},"lqip":"data:image/jpeg;base64,"},"tags":null},"caption":null,"crop":null},{"_key":"4a9f5562ff6c","_type":"block","children":[{"_key":"4c04b21752150","_type":"span","marks":[],"text":"In Renzo Piano Building Workshop’s design for Maison Hermès in Tokyo, a luminous facade of glass blocks shapes the building’s distinctive character. The gridded surface captures and diffuses light, transforming the structure into a glowing beacon within the city. This material lends both structural precision and an ethereal sense of openness."}],"markDefs":[],"style":"normal"},{"_key":"fd08f03242a1","_type":"block","children":[{"_key":"1610ebfe9060","_type":"span","marks":[],"text":""}],"markDefs":[],"style":"normal"},{"_key":"95ea70e73b1f","_type":"image","alt":"Maison Hermès glass blocks","asset":{"_id":"image-aa0023a5362cdc04e959cb92f9c6c0620e4891a8-762x971-jpg","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":0.7847579814624099,"height":971,"width":762},"lqip":"data:image/jpeg;base64,"},"tags":null},"caption":null,"crop":null}],"featuredImage":{"_key":null,"_type":"image","asset":{"_id":"image-d6226efb5579f86fc5b5892fc8d870e080f4b417-1080x1350-png","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":0.8,"height":1350,"width":1080},"lqip":"data:image/png;base64,"},"tags":null},"caption":null,"crop":null},"publishedAt":"2025-11-18","slug":"glass-blocks","summary":"From raw origins to refined forms, we spotlight the materials that shape how we build, live, and experience spaces.\n\n","title":"Matter of Design | Glass Blocks"},"nextInsight":{"_id":"cf989a78-dd92-4d24-9f18-2f62a34aa866","_type":"insight","content":[{"_key":"e5369a29cc69","_type":"block","children":[{"_key":"c3de22267bcb0","_type":"span","marks":[],"text":"Fast casual dining has exploded across New York City, reshaping neighborhoods and redefining how people eat out. With retail availability at historic lows and food and beverage tenants outpacing every other retail sector in leasing, the competition to stand out has never been greater. Great food may draw people in, but it’s thoughtful design that transforms a restaurant into a destination."}],"markDefs":[],"style":"normal"},{"_key":"293ee1e1571d","_type":"image","alt":"bolt builds ","asset":{"_id":"image-be7fc9251821118ce763dcb87468292b9e9530c1-1439x2014-png","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":0.714498510427011,"height":2014,"width":1439},"lqip":"data:image/png;base64,"},"tags":null},"caption":null,"crop":null},{"_key":"845821d31427","_type":"block","children":[{"_key":"e3b5a81a3da80","_type":"span","marks":[],"text":"That’s where Bolt Builds steps in. By streamlining design, build, and fabrication under one roof, Bolt helps fast casual brands bring their vision to life quickly and cohesively, without sacrificing craft or creativity. But our role begins even earlier: we partner with hospitality and retail clients before a lease is even signed, analyzing potential spaces, flagging costly red tape, and helping negotiate smarter terms. This proactive approach, combined with deep research into NYC’s fast-moving hospitality market, positions each project for long-term success."}],"markDefs":[],"style":"normal"},{"_key":"58306d0db62d","_type":"block","children":[{"_key":"35e018644b7f0","_type":"span","marks":[],"text":"\nEvery detail, from architectural elements to custom finishes, plays a role in creating spaces that resonate with guests and optimize the flow of business. To ensure a seamless process, Bolt provides clients with dedicated project websites offering daily updates, real-time photos, and transparent decision timelines. From permitting and approvals to fabrication and installation, the path from concept to grand opening is navigated with precision and clarity."}],"markDefs":[],"style":"normal"},{"_key":"0f661d0c0783","_type":"block","children":[{"_key":"7c0fc549ca4c","_type":"span","marks":[],"text":""}],"markDefs":[],"style":"normal"},{"_key":"f43ffd8438ae","_type":"image","alt":"upside pizza","asset":{"_id":"image-b5207bd8475c25fea54ecde93269495b1022bfcd-1080x1350-png","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":0.8,"height":1350,"width":1080},"lqip":"data:image/png;base64,"},"tags":null},"caption":null,"crop":null},{"_key":"06bb401f21d9","_type":"block","children":[{"_key":"2edd1e9009170","_type":"span","marks":[],"text":"Consider Upside Pizza. In SoHo, Bolt crafted a warm, nostalgic pizzeria atmosphere through custom wood paneling, bold green banquettes, and soft lighting. In Greenpoint, the same signature checkered pattern was adapted with exposed brick and glass to feel both familiar and modern."}],"markDefs":[],"style":"normal"},{"_key":"10799b6243df","_type":"image","alt":"upside pizza","asset":{"_id":"image-a4181cd96caec6aaa76dd205af8fc0dccd1ce57e-2300x1294-jpg","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":1.777434312210201,"height":1294,"width":2300},"lqip":"data:image/jpeg;base64,"},"tags":null},"caption":null,"crop":null},{"_key":"a966b9b8e2a7","_type":"block","children":[{"_key":"352806f2fbcc0","_type":"span","marks":[],"text":"For Norm’s Pizza in Park Slope, Bolt blended retro charm with contemporary design, using glossy yellow tile, brick walls, and custom pegboard details to evoke the spirit of a neighborhood classic with a fresh edge.\n\n"}],"markDefs":[],"style":"normal"},{"_key":"d2b548372c7e","_type":"image","alt":"norms pizza","asset":{"_id":"image-3487370b0e16a6d4519d469b5a097b9e913c903b-1533x2200-png","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":0.6968181818181818,"height":2200,"width":1533},"lqip":"data:image/png;base64,"},"tags":null},"caption":null,"crop":null},{"_key":"9292356796c6","_type":"block","children":[{"_key":"5fdb680a59310","_type":"span","marks":[],"text":"Bolt also partnered with Springbone Kitchen on multiple locations, translating their philosophy of natural wellness into built environments that feel timeless and calming. Through elements like curved oak soffits, custom bar stools, and handcrafted facades, each location reflects both the brand’s identity and the unique character of its neighborhood."}],"markDefs":[],"style":"normal"},{"_key":"b52dba2ab441","_type":"image","alt":"springbone","asset":{"_id":"image-4bc84f9c9b2c56ddcc282c7f0d7c8779ccd2fa5e-2400x1350-png","_type":"sanity.imageAsset","desc