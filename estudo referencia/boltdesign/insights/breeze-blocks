97218a0","_type":"insight","content":[{"_key":"84769fd5b498","_type":"block","children":[{"_key":"7e3ef67a15d9","_type":"span","marks":[],"text":"Breeze Blocks"}],"markDefs":[],"style":"h2"},{"_key":"4dd6723e55bd","_type":"block","children":[{"_key":"005785c7918f","_type":"span","marks":[],"text":"\nFrom raw origins to refined forms, we spotlight the materials that shape how we build, live, and experience spaces."}],"markDefs":[],"style":"normal"},{"_key":"3e160f1a4456","_type":"image","alt":"breeze blocks bolt builds ","asset":{"_id":"image-2fe2736c44ecda8cdfe78798f77c408ee835c414-1920x1080-png","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":1.7777777777777777,"height":1080,"width":1920},"lqip":"data:image/png;base64,"},"tags":null},"caption":null,"crop":null},{"_key":"7113f986627b","_type":"block","children":[{"_key":"40b72b0992990","_type":"span","marks":[],"text":"These patterned decorative blocks made of concrete or clay became popular in the 1950s and ’60s Mid-Century Modern era. Used on walls and facades, they provide shade, airflow, privacy, and protection. All while adding stylish geometric patterns, especially suited to warmer climates."}],"markDefs":[],"style":"normal"},{"_key":"ed0aec1138e2","_type":"image","alt":"breeze blocks tamara wibowo architects ","asset":{"_id":"image-32ab7746ef01cf8cb0fe82905378ddbf52e9528b-1000x563-jpg","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":1.7761989342806395,"height":563,"width":1000},"lqip":"data:image/jpeg;base64,"},"tags":null},"caption":null,"crop":null},{"_key":"aa6fcfca6596","_type":"block","children":[{"_key":"787a10779406","_type":"span","marks":[],"text":"Breeze Blocks House by Tamara Wibowo Architects uses breeze blocks as a defining feature, shaping both the exterior and interior of the home. These patterned blocks create natural ventilation and filtered light throughout the space, enhancing comfort while adding distinctive texture and privacy. The design celebrates the material’s functional beauty, seamlessly blending openness with shelter in a modern, thoughtful way."}],"markDefs":[],"style":"normal"},{"_key":"b504e237bd6f","_type":"block","children":[{"_key":"5adbd04087d5","_type":"span","marks":[],"text":""}],"markDefs":[],"style":"normal"},{"_key":"d76f5f1d6635","_type":"image","alt":"Breeze Blocks House Tamara Wibowo Architects","asset":{"_id":"image-7ce9a3446238bc9c3e255ae7afed60a3a1090e97-810x1080-jpg","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":0.75,"height":1080,"width":810},"lqip":"data:image/jpeg;base64,"},"tags":null},"caption":null,"crop":null},{"_key":"e359ee631931","_type":"block","children":[{"_key":"9c4ffae3ee63","_type":"span","marks":[],"text":""}],"markDefs":[],"style":"normal"},{"_key":"75937f607a69","_type":"image","alt":"Inca Hernández Arquitectura Breeze Blocks","asset":{"_id":"image-3a689812c0ac099cf607a508d90508a69e253e4e-2132x1199-jpg","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":1.7781484570475397,"height":1199,"width":2132},"lqip":"data:image/jpeg;base64,"},"tags":null},"caption":null,"crop":null},{"_key":"42dcca9fc23b","_type":"block","children":[{"_key":"9490cf7a878f0","_type":"span","marks":[],"text":"Mar Mediterráneo 34 in Mexico City, restored by Inca Hernández Arquitectura, brings new life to a 1910 house by preserving original details like the façade and balconies. The project introduces patios with breeze blocks that allow natural light and airflow while providing privacy and texture. This thoughtful use of the material creates a perfect balance between historic charm and breathable, inviting spaces.\n\n"}],"markDefs":[],"style":"normal"},{"_key":"ed7aeda69ad9","_type":"image","alt":"Inca Hernández Arquitectura Breeze Blocks","asset":{"_id":"image-70749ccb3630a7baf33a6b5d009528f212764fca-1333x2000-jpg","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":0.6665,"height":2000,"width":1333},"lqip":"data:image/jpeg;base64,"},"tags":null},"caption":null,"crop":null}],"featuredImage":{"_key":null,"_type":"image","asset":{"_id":"image-6f74a9fd05606826b72b4f7a4fe9138829e55af2-1920x1080-png","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":1.7777777777777777,"height":1080,"width":1920},"lqip":"data:image/png;base64,"},"tags":null},"caption":null,"crop":null},"publishedAt":"2025-07-08","slug":"breeze-blocks","summary":"From raw origins to refined forms, we spotlight the materials that shape how we build, live, and experience spaces.","title":"Matter of Design | Breeze Blocks "},"nextInsight":{"_id":"710f8d65-8e25-4d4e-8e9b-b56f3d232a20","_type":"insight","content":[{"_key":"97ad87bb3576","_type":"block","children":[{"_key":"600769fa56800","_type":"span","marks":[],"text":"2025 brought a wide range of projects across the hospitality and commercial world."}],"markDefs":[],"style":"normal"},{"_key":"23f8233dfee0","_type":"block","children":[{"_key":"862a9bec5f6b0","_type":"span","marks":[],"text":"Each project was shaped with the same intention and collaboration that define our work. With our integrated design and fabrication process, we were able to move quickly and keep every detail aligned. As we look back, we’re excited to highlight three standout projects that helped make this year one of our most dynamic yet.\n\n"}],"markDefs":[],"style":"normal"},{"_key":"e89f3da5ef5e","_type":"image","alt":"mazarine","asset":{"_id":"image-4e884f43714011c630994d902f3d6560b419f5bf-1600x1067-jpg","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":1.499531396438613,"height":1067,"width":1600},"lqip":"data:image/jpeg;base64,"},"tags":null},"caption":null,"crop":null},{"_key":"720de51d75b4","_type":"block","children":[{"_key":"60206a99521f0","_type":"span","marks":[],"text":"We’re opening our 2025 year-end recap with Mazarine, a new restaurant in Mayfair, London, created for Mandarin Oriental Hotels. We conceptualized and designed the space alongside RedPuzzle Hospitality and it was brought to life by OPUS Interiors. Shaped by soft curves, layered lighting, and an elevated material palette—the interior avoids literal references, instead focusing on atmosphere and spatial flow to create a calm, sculpted dining experience that feels immersive, considered, and quietly luxurious."}],"markDefs":[],"style":"normal"},{"_key":"4ad61e81a1ca","_type":"block","children":[{"_key":"f9340cf577c4","_type":"span","marks":[],"text":""}],"markDefs":[],"style":"normal"},{"_key":"1eeda193d5a2","_type":"image","alt":"mazarine","asset":{"_id":"image-4203e5a486e905454cf07724c9ac76863feb451e-1080x1350-png","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":0.8,"height":1350,"width":1080},"lqip":"data:image/png;base64,"},"tags":null},"caption":null,"crop":null},{"_key":"81701c38ea7a","_type":"block","children":[{"_key":"190bc7224e08","_type":"span","marks":[],"text":""}],"markDefs":[],"style":"normal"},{"_key":"a06ed1b4cf37","_type":"image","alt":"softbar","asset":{"_id":"image-56a6ea15b8c4d03b692d61d8f38fb51991642033-1080x1350-png","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":0.8,"height":1350,"width":1080},"lqip":"data:image/png;base64,"},"tags":null},"caption":null,"crop":null},{"_key":"5cc3fb25dd3f","_type":"block","children":[{"_key":"05a1ca8b17640","_type":"span","marks":[],"text":"At Soft Bar + Café, our team shaped two defining features of the space: a custom-built arch ceiling and a monolithic, cast-in-place infinity bar. Piece by piece, the ceiling’s framing and finish work set the tone for the room, while the soft green dyed concrete bar was poured and crafted on site to achieve its seamless, sculptural form. Together, these elements anchor the café with a calm, contemporary presence that feels both immersive and effortlessly refined."}],"markDefs":[],"style":"normal"},{"_key":"dd3eda1817b7","_type":"image","alt":"soft bar","asset":{"_id":"image-62a075ebcfe5a9756a3db21bf2a47df0b1dff4b6-1080x1440-jpg","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":0.75,"height":1440,"width":1080},"lqip":"data:image/jpeg;base64,"},"tags":null},"caption":null,"crop":null},{"_key":"b9d7850f8a3b","_type":"image","alt":"redbull","asset":{"_id":"image-4622ff30413f28bd4857e19f12f0b503a36c4ddd-1920x1350-png","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":1.4222222222222223,"height":1350,"width":1920},"lqip":"data:image/png;base64,"},"tags":null},"caption":null,"crop":null},{"_key":"ac0036fa9332","_type":"block","children":[{"_key":"23df4ec6294d0","_type":"span","marks":[],"text":"To wrap up the year, we’re highlighting a versatile fabrication project— a modular event space for Red Bull, featuring a custom steel frame and McNICHOLS perforated metal panels. Designed for high-volume venues, the installation incorporates integrated digital displays, durable pre-finished lower panels, and illuminated branding. The result is a sleek, functional structure that delivers both performance and a bold visual presence in the event space."}],"markDefs":[],"style":"normal"},{"_key":"fb2c00dafd6e","_type":"block","children":[{"_key":"60ee1f324286","_type":"span","marks":[],"text":""}],"markDefs":[],"style":"normal"},{"_key":"0afef3d2e4be","_type":"image","alt":"redbull","asset":{"_id":"image-1507830d35c8365824136f12a6277d9d04aa9661-1080x1350-png","_type":"sanity.imageAsset","description":null,"metadata":{"dimensions":{"aspectRatio":0.8,"height":1350,"width":1080},"lqip":"data:image/png;base64,"},"tags":null},"caption":null,"crop":null},{"_key":"e49b36c7bdcd","_type":"block","children":[{"_key":"b4bfbea813730","_type":"span","marks":[],"text":"Beyond these features, this year was defined by a full slate of work across "},{"_key":"b4bfbea813731","_type":"span","marks":["str